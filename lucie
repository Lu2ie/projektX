<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reaktionsspiel</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            font-family: Arial, sans-serif;
        }

        .game-container {
            text-align: center;
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            width: 500px;
        }

        h1 {
            color: #333;
            margin: 0 0 30px 0;
        }

        .stats {
            display: flex;
            justify-content: space-around;
            margin-bottom: 30px;
            font-size: 18px;
        }

        .stat {
            background: #f0f0f0;
            padding: 15px 20px;
            border-radius: 8px;
            min-width: 120px;
        }

        .stat-label {
            color: #666;
            font-size: 14px;
            margin-bottom: 5px;
        }

        .stat-value {
            color: #667eea;
            font-weight: bold;
            font-size: 28px;
        }

        .game-box {
            width: 100%;
            height: 250px;
            margin: 30px 0;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: bold;
            color: white;
            cursor: pointer;
            transition: all 0.3s;
            user-select: none;
        }

        .game-box.waiting {
            background: #ff6b6b;
            cursor: not-allowed;
        }

        .game-box.ready {
            background: #51cf66;
            cursor: pointer;
            font-size: 48px;
        }

        .game-box.active {
            background: #4ecdc4;
            transform: scale(0.98);
        }

        .controls {
            margin-bottom: 20px;
        }

        button {
            padding: 12px 30px;
            font-size: 16px;
            background: #667eea;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.3s;
            margin: 0 10px;
        }

        button:hover {
            background: #5568d3;
        }

        button:disabled {
            background: #ccc;
            cursor: not-allowed;
        }

        .result {
            margin-top: 20px;
            font-size: 18px;
            min-height: 30px;
            font-weight: bold;
        }

        .result.success {
            color: #51cf66;
        }

        .result.fail {
            color: #ff6b6b;
        }
    </style>
</head>
<body>
    <div class="game-container">
        <h1>⚡ Reaktionsspiel</h1>

        <div class="stats">
            <div class="stat">
                <div class="stat-label">Versuche</div>
                <div class="stat-value" id="attempts">0</div>
            </div>
            <div class="stat">
                <div class="stat-label">Beste Zeit</div>
                <div class="stat-value" id="bestTime">-</div>
            </div>
        </div>

        <div class="game-box" id="gameBox">Warte...</div>

        <div class="controls">
            <button id="startBtn" onclick="startGame()">Spiel starten</button>
            <button id="resetBtn" onclick="resetGame()">Zurücksetzen</button>
        </div>

        <div class="result" id="result"></div>
    </div>

    <script>
        let startTime = 0;
        let gameActive = false;
        let attempts = 0;
        let bestTime = null;
        const gameBox = document.getElementById('gameBox');
        const result = document.getElementById('result');
        const attemptsDisplay = document.getElementById('attempts');
        const bestTimeDisplay = document.getElementById('bestTime');
        const startBtn = document.getElementById('startBtn');

        function startGame() {
            if (gameActive) return;

            gameActive = false;
            attempts++;
            attemptsDisplay.textContent = attempts;
            result.textContent = '';
            result.className = 'result';
            gameBox.className = 'game-box waiting';
            gameBox.textContent = 'Warte...';
            startBtn.disabled = true;

            // Zufällige Wartezeit 1-4 Sekunden
            const delay = Math.random() * 3000 + 1000;

            setTimeout(() => {
                gameBox.className = 'game-box ready';
                gameBox.textContent = 'KLICK!';
                startTime = Date.now();
                gameActive = true;
            }, delay);
        }

        function resetGame() {
            gameActive = false;
            attempts = 0;
            bestTime = null;
            attemptsDisplay.textContent = '0';
            bestTimeDisplay.textContent = '-';
            gameBox.className = 'game-box waiting';
            gameBox.textContent = 'Warte...';
            result.textContent = '';
            startBtn.disabled = false;
        }

        gameBox.addEventListener('click', () => {
            if (!gameActive) {
                result.className = 'result fail';
                result.textContent = '❌ Zu früh! Warte auf KLICK!';
                return;
            }

            const reactionTime = Date.now() - startTime;
            gameActive = false;
            gameBox.className = 'game-box active';
            result.className = 'result success';
            result.textContent = `⚡ Deine Zeit: ${reactionTime}ms`;

            // Best time aktualisieren
            if (bestTime === null || reactionTime < bestTime) {
                bestTime = reactionTime;
                bestTimeDisplay.textContent = reactionTime + 'ms';
            }

            startBtn.disabled = false;
        });
    </script>
</body>
</html>
